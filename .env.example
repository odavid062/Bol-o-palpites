NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# --- Placar automático ao vivo (football-data.org) ---
# Token gratuito: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=seu_token_football_data
# Temporada da Copa (padrão 2026)
FOOTBALL_DATA_SEASON=2026
# Service role do Supabase (Project Settings > API). SECRETO — só no servidor.
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
# Segredo para proteger a rota /api/cron/sync-jogos (gere um valor aleatório)
CRON_SECRET=um_valor_aleatorio_secreto
